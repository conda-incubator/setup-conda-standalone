{
  "name": "setup-conda-standalone",
  "version": "0.1.0",
  "private": true,
  "description": "Action to set up conda-standalone",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "all": "run-s build lint-fix test",
    "build": "run-s type-check compile",
    "compile": "tsdown",
    "dev": "tsdown --watch",
    "eslint": "eslint",
    "eslint-fix": "eslint --fix",
    "lint": "run-s eslint prettier",
    "lint-fix": "run-s eslint-fix prettier-fix",
    "prettier": "prettier --check '**/*.{cjs,js,json,mjs,mts,ts}'",
    "prettier-fix": "prettier --write --check '**/*.{cjs,js,json,mjs,mts,ts}'",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/tool-cache": "4.0.0",
    "dev": "0.1.3",
    "typescript": "5.9.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@containerbase/eslint-plugin": "^1.1.34",
    "@eslint/js": "9.39.3",
    "@microsoft/tsdoc": "0.16.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "25.3.1",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/eslint-plugin": "1.6.9",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-formatter-gha": "2.0.1",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-import-zod": "^1.2.1",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-tsdoc": "0.5.2",
    "globals": "17.3.0",
    "js-yaml": "^4.1.1",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "tsdown": "0.20.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18"
  }
}
