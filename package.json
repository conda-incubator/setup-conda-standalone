{
  "name": "setup-conda-standalone",
  "version": "0.1.0",
  "private": true,
  "description": "Action to set up conda-standalone",
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "all": "run-s build lint-fix test",
    "build": "run-s type-check compile",
    "compile": "tsdown",
    "dev": "tsdown --watch",
    "eslint": "eslint",
    "eslint-fix": "eslint --fix",
    "lint": "run-s eslint prettier",
    "lint-fix": "run-s eslint-fix prettier-fix",
    "prettier": "prettier --cache --check '**/*.{cjs,js,json,mjs,mts,ts}'",
    "prettier-fix": "prettier --write --cache --check '**/*.{cjs,js,json,mjs,mts,ts}'",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@actions/core": "3.0.0",
    "@actions/tool-cache": "4.0.0",
    "dev": "0.1.3",
    "typescript": "5.9.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "25.3.1",
    "@vitest/coverage-v8": "4.0.18",
    "globals": "17.3.0",
    "js-yaml": "^4.1.1",
    "npm-run-all2": "8.0.4",
    "tsdown": "0.20.3",
    "vitest": "4.0.18"
  }
}
